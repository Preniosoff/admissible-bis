{
  "name": "admissible-bis",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "PORT=3001 node --watch server/index.js",
    "dev:client": "vite --port 3000",
    "build": "vite build",
    "start": "node server/index.js",
    "seed": "node server/db/seed.js",
    "migrate": "node scripts/migrate.js",
    "backup": "node scripts/backup-db.js",
    "snapshot": "node scripts/snapshot-db.js",
    "site:teasing": "node scripts/site-mode.js teasing",
    "site:live": "node scripts/site-mode.js live"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.10",
    "sql.js": "^1.11.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
